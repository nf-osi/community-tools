SYNAPSE_AUTH_TOKEN=your_service_account_token_here

SYNAPSE_OAUTH_CLIENT_ID=your_oauth_client_id
SYNAPSE_OAUTH_CLIENT_SECRET=your_oauth_client_secret

# Must match the redirect URI registered in your Synapse OAuth client.
OAUTH_REDIRECT_URI=http://127.0.0.1:9000/oauth/callback
# In dev: http://127.0.0.1:5173 (must match Vite host — use 127.0.0.1, not localhost, so
# the session cookie domain is consistent with the OAuth redirect URI above).
# In production: leave unset (defaults to /)
POST_LOGIN_URL=

# Random string for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me_in_production

PORT=9000

# Set to "production" to enable secure (HTTPS-only) session cookies.
# Vercel sets this automatically; set it manually for other production hosts.
NODE_ENV=development
