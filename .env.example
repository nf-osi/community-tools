SYNAPSE_AUTH_TOKEN=your_service_account_token_here

# Local-dev only: skip OAuth and sign in as the service token's Synapse user via
# /api/auth/login. Hard-disabled when NODE_ENV=production. Leave unset/false once
# a real OAuth client is configured.
DEV_AUTH_BYPASS=false

SYNAPSE_OAUTH_CLIENT_ID=your_oauth_client_id
SYNAPSE_OAUTH_CLIENT_SECRET=your_oauth_client_secret

# Must match the redirect URI registered in your Synapse OAuth client.
OAUTH_REDIRECT_URI=http://127.0.0.1:9000/oauth/callback
# In dev: http://127.0.0.1:5173 (must match Vite host — use 127.0.0.1, not localhost, so
# the session cookie domain is consistent with the OAuth redirect URI above).
# In production: leave unset (defaults to /)
POST_LOGIN_URL=

# Random string for signing session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me_in_production

PORT=9000

# Set to "production" to enable secure (HTTPS-only) session cookies.
# Vercel sets this automatically; set it manually for other production hosts.
NODE_ENV=development

# ── GitHub issue mirroring (optional) ─────────────────────────────────────────
# When set, each submitted idea also opens a GitHub issue for team triage. Leave
# GITHUB_TOKEN unset to disable (submissions still succeed without a linked issue).
# Needs a token with "issues: write" (fine-grained) or "repo" (classic) scope.
GITHUB_TOKEN=
# owner/repo that receives the issues.
GITHUB_ISSUE_REPO=nf-osi/community-tools
# Comma-separated GitHub usernames to assign each issue to.
GITHUB_ISSUE_ASSIGNEES=BelindaBGarana

# ── GWAS agent (/api/gwas/*) ──────────────────────────────────────────────────
# Anthropic key for the pre-flight file-check agent (/api/gwas/check-files).
ANTHROPIC_API_KEY=
# Optional model override for the file-check agent.
GWAS_CHECK_MODEL=claude-sonnet-4-6
# Name or ARN of the AWS Batch submit Lambda (CloudFormation output SubmitFunctionName).
GWAS_SUBMIT_FUNCTION=nf-gwas-submit
# Dev-only dry-run: /api/gwas/submit validates and returns a confirmation but does
# NOT launch a job. Hard-disabled when NODE_ENV=production.
GWAS_DRY_RUN=false
# AWS region + credentials for invoking the Lambda (standard AWS_* env / role).
AWS_REGION=us-east-1
